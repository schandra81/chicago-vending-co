---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { posts } from '../../content/blog/posts';
---

<Base
  title="Vending Machine Blog for Chicago Businesses | Chicago Vending Co."
  description="Guides, tips, and insights for Chicago facility managers and HR teams on vending machines, healthy break rooms, office coffee, and micro-markets."
  canonical="https://chicagovendingco.com/blog"
>
  <Nav />
  <main>
    <section class="blog-hero">
      <div class="container">
        <div class="blog-hero-label">Resources &amp; Insights</div>
        <h1>The Chicago Vending<br>Resource Center</h1>
        <p>Practical guides for Chicago facility managers, HR leaders, and property owners on vending, break rooms, and workplace amenities.</p>
      </div>
    </section>

    <div class="filter-bar">
      <div class="container">
        <div class="filter-inner">
          <button class="filter-btn active" data-cat="all">All Articles</button>
          <button class="filter-btn" data-cat="guide">Guides</button>
          <button class="filter-btn" data-cat="health">Health &amp; Wellness</button>
          <button class="filter-btn" data-cat="coffee">Coffee</button>
          <button class="filter-btn" data-cat="comparison">Comparisons</button>
          <button class="filter-btn" data-cat="hr">HR &amp; Culture</button>
        </div>
      </div>
    </div>

    <!-- Featured post -->
    <section class="featured-section">
      <div class="container">
        <div class="featured-label">Featured Article</div>
        <a href={`/blog/${posts[0].slug}`} class="featured-post">
          <div class="featured-post-img">
            <div class="fp-category">{posts[0].category}</div>
            <img src={posts[0].image} alt={posts[0].imageAlt} loading="eager"/>
          </div>
          <div class="featured-post-body">
            <div class="fp-meta">
              <span>{posts[0].date}</span>
              <span>{posts[0].readTime}</span>
            </div>
            <h2>{posts[0].title}</h2>
            <p>{posts[0].excerpt}</p>
            <div class="fp-tags">
              {posts[0].tags.map(tag => <span class="fp-tag">{tag}</span>)}
            </div>
            <span class="btn-primary">Read full article →</span>
          </div>
        </a>
      </div>
    </section>

    <!-- All posts grid -->
    <section class="posts-section">
      <div class="container">
        <div class="posts-label">All Articles</div>
        <div class="posts-grid" id="postsGrid">
          {posts.slice(1).map(post => (
            <a href={`/blog/${post.slug}`} class="post-card" data-cats={post.category.toLowerCase().replace(/\s*&\s*/g, '-').replace(/\s+/g, '-')}>
              <div class="post-card-img">
                <div class="post-category">{post.category}</div>
                <img src={post.image} alt={post.imageAlt} loading="lazy"/>
              </div>
              <div class="post-body">
                <div class="post-meta">
                  <span>{post.date}</span>
                  <span>{post.readTime}</span>
                </div>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
                <div class="post-tags">
                  {post.tags.slice(0, 3).map(tag => <span class="post-tag">{tag}</span>)}
                </div>
                <span class="post-link">Read article →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="newsletter-section">
      <div class="container">
        <div class="newsletter-inner">
          <div class="newsletter-copy">
            <h3>Stay ahead of the break room</h3>
            <p>Monthly tips on vending, healthy snacks, and workplace amenities — for Chicago facility and HR teams.</p>
          </div>
          <form class="newsletter-form" id="nlForm">
            <input type="email" placeholder="Your work email address" required/>
            <button type="submit" class="newsletter-btn">Subscribe →</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="blog-footer">
    <div class="container">
      <div class="blog-footer-inner">
        <a href="/" class="footer-logo">
          <span style="color:var(--c-orange);font-size:20px">◈</span>
          <span>Chicago<strong style="color:var(--c-orange);font-weight:500">Vending</strong></span>
        </a>
        <div class="blog-footer-links">
          <a href="/">← Back to homepage</a>
          <a href="/#quiz">Get Free Quote</a>
          <a href="/contact">Contact</a>
        </div>
        <p>&copy; 2025 Chicago Vending Co.</p>
      </div>
    </div>
  </footer>
</Base>

<style>
  /* Blog Hero */
  .blog-hero{padding:140px 0 72px;background:var(--c-near-black);border-bottom:1px solid var(--c-border)}
  .blog-hero-label{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--c-orange);font-weight:500;margin-bottom:16px}
  .blog-hero h1{font-family:var(--font-display);font-size:clamp(48px,8vw,96px);font-weight:400;margin-bottom:16px}
  .blog-hero p{font-size:17px;color:rgba(248,245,240,.6);max-width:520px}

  /* Filter */
  .filter-bar{padding:24px 0;border-bottom:1px solid var(--c-border);background:var(--c-near-black);position:sticky;top:68px;z-index:50;backdrop-filter:blur(8px)}
  .filter-inner{display:flex;gap:10px;flex-wrap:wrap}
  .filter-btn{background:rgba(255,255,255,.05);border:1px solid var(--c-border);border-radius:100px;padding:8px 18px;font-family:var(--font-body);font-size:13px;color:rgba(248,245,240,.7);cursor:pointer;transition:all .15s}
  .filter-btn:hover,.filter-btn.active{background:rgba(255,78,0,.15);border-color:rgba(255,78,0,.4);color:var(--c-white)}

  /* Featured */
  .featured-section{padding:60px 0 0}
  .featured-label{font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:rgba(248,245,240,.3);font-weight:500;margin-bottom:20px}
  .featured-post{display:grid;grid-template-columns:1fr 1fr;background:var(--c-dark);border:1px solid var(--c-border);border-radius:var(--radius-lg);overflow:hidden;transition:border-color .2s}
  .featured-post:hover{border-color:rgba(255,78,0,.35)}
  .featured-post-img{position:relative;height:460px}
  .featured-post-img img{width:100%;height:100%;object-fit:cover;filter:brightness(.8)}
  .fp-category{position:absolute;top:20px;left:20px;background:var(--c-orange);color:#fff;font-size:11px;font-weight:500;padding:5px 14px;border-radius:100px;z-index:1}
  .featured-post-body{padding:48px;display:flex;flex-direction:column;justify-content:center;gap:14px}
  .fp-meta{display:flex;gap:16px;font-size:12px;color:rgba(248,245,240,.4)}
  .featured-post-body h2{font-size:clamp(20px,2.5vw,28px);font-weight:500;line-height:1.3}
  .featured-post-body p{font-size:15px;color:rgba(248,245,240,.65);line-height:1.7}
  .fp-tags{display:flex;gap:8px;flex-wrap:wrap}
  .fp-tag{font-size:12px;background:rgba(255,255,255,.06);border:1px solid var(--c-border);padding:4px 12px;border-radius:100px;color:rgba(248,245,240,.55)}
  .btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--c-orange);color:#fff;padding:14px 22px;border-radius:var(--radius);font-size:15px;font-weight:500;width:fit-content;transition:background .2s}
  .btn-primary:hover{background:var(--c-orange-dark)}
  @media(max-width:900px){.featured-post{grid-template-columns:1fr}.featured-post-img{height:260px}.featured-post-body{padding:28px}}

  /* Posts grid */
  .posts-section{padding:60px 0 100px}
  .posts-label{font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:rgba(248,245,240,.3);font-weight:500;margin-bottom:24px}
  .posts-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .post-card{display:flex;flex-direction:column;background:var(--c-dark);border:1px solid var(--c-border);border-radius:var(--radius-lg);overflow:hidden;transition:border-color .2s,transform .2s}
  .post-card:hover{border-color:rgba(255,78,0,.35);transform:translateY(-4px)}
  .post-card-img{position:relative;height:200px;overflow:hidden}
  .post-card-img img{width:100%;height:100%;object-fit:cover;filter:brightness(.8);transition:transform .5s}
  .post-card:hover .post-card-img img{transform:scale(1.05)}
  .post-category{position:absolute;top:12px;left:12px;background:var(--c-orange);color:#fff;font-size:11px;font-weight:500;padding:4px 10px;border-radius:100px}
  .post-body{padding:24px;display:flex;flex-direction:column;flex:1}
  .post-meta{display:flex;gap:12px;font-size:12px;color:rgba(248,245,240,.4);margin-bottom:10px}
  .post-body h3{font-size:17px;font-weight:500;line-height:1.35;margin-bottom:10px}
  .post-body p{font-size:14px;color:rgba(248,245,240,.6);line-height:1.65;margin-bottom:16px;flex:1}
  .post-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
  .post-tag{font-size:11px;background:rgba(255,255,255,.05);border:1px solid var(--c-border);padding:3px 10px;border-radius:100px;color:rgba(248,245,240,.45)}
  .post-link{font-size:13px;color:var(--c-orange);font-weight:500}

  /* Newsletter */
  .newsletter-section{padding:80px 0;background:var(--c-near-black);border-top:1px solid var(--c-border)}
  .newsletter-inner{display:flex;gap:48px;align-items:center;flex-wrap:wrap}
  .newsletter-copy{flex:1;min-width:280px}
  .newsletter-copy h3{font-family:var(--font-display);font-size:clamp(28px,4vw,44px);font-weight:400;margin-bottom:10px}
  .newsletter-copy p{font-size:15px;color:rgba(248,245,240,.6)}
  .newsletter-form{display:flex;gap:10px;flex:1;min-width:280px}
  .newsletter-form input{flex:1;background:rgba(255,255,255,.06);border:1px solid var(--c-border);border-radius:var(--radius);padding:14px 16px;color:var(--c-white);font-family:var(--font-body);font-size:15px}
  .newsletter-form input:focus{outline:none;border-color:rgba(255,78,0,.5)}
  .newsletter-form input::placeholder{color:rgba(248,245,240,.35)}
  .newsletter-btn{background:var(--c-orange);color:#fff;border:none;border-radius:var(--radius);padding:14px 22px;font-family:var(--font-body);font-size:15px;font-weight:500;cursor:pointer;white-space:nowrap}
  .newsletter-btn:hover{background:var(--c-orange-dark)}

  /* Blog footer */
  .blog-footer{background:var(--c-near-black);border-top:1px solid var(--c-border);padding:40px 0}
  .blog-footer-inner{display:flex;flex-direction:column;gap:16px;align-items:center;text-align:center;font-size:13px;color:rgba(248,245,240,.35)}
  .footer-logo{display:flex;align-items:center;gap:10px;font-size:17px;color:var(--c-white)}
  .blog-footer-links{display:flex;gap:28px;flex-wrap:wrap;justify-content:center}
  .blog-footer-links a{font-size:14px;color:rgba(248,245,240,.5);transition:color .2s}
  .blog-footer-links a:hover{color:var(--c-orange)}

  @media(max-width:900px){.posts-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:600px){.posts-grid{grid-template-columns:1fr}}
</style>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      const cat = this.getAttribute('data-cat');
      document.querySelectorAll('.post-card').forEach((card: any) => {
        const cats = card.getAttribute('data-cats') || '';
        card.style.display = (cat === 'all' || cats.includes(cat)) ? 'flex' : 'none';
      });
    });
  });
  document.getElementById('nlForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = (this as HTMLFormElement).querySelector('button') as HTMLButtonElement;
    btn.textContent = '✅ Subscribed!';
    btn.style.background = '#16a34a';
    btn.disabled = true;
  });
</script>
