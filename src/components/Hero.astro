<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex; align-items: center;
    padding: 120px 0 80px;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: linear-gradient(160deg, #0A0A0A 0%, #111008 50%, #0A0A0A 100%);
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,78,0,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,78,0,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-skyline {
    position: absolute; bottom: 0; left: 0; right: 0;
    pointer-events: none;
  }
  .hero-skyline svg { width: 100%; display: block; }

  .hero-content {
    position: relative; z-index: 2;
    max-width: 800px;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,78,0,0.12); border: 1px solid rgba(255,78,0,0.3);
    color: var(--c-orange-light); font-size: 13px; font-weight: 500;
    padding: 6px 14px; border-radius: 100px;
    margin-bottom: 28px;
    animation: fadeUp 0.6s ease both;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(72px, 12vw, 140px);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--c-white);
    margin-bottom: 24px;
    display: flex; flex-direction: column;
  }
  .hero-line-1 { animation: fadeUp 0.6s 0.1s ease both; }
  .hero-line-2 {
    color: var(--c-orange);
    animation: fadeUp 0.6s 0.2s ease both;
    -webkit-text-stroke: 2px var(--c-orange);
    color: transparent;
  }
  .hero-line-3 { animation: fadeUp 0.6s 0.3s ease both; }
  .hero-sub {
    font-size: 18px; line-height: 1.6;
    color: rgba(248,245,240,0.7);
    margin-bottom: 36px;
    max-width: 480px;
    animation: fadeUp 0.6s 0.4s ease both;
  }
  .hero-sub strong { color: var(--c-white); font-weight: 500; }
  .hero-actions {
    display: flex; gap: 16px; flex-wrap: wrap; align-items: center;
    margin-bottom: 48px;
    animation: fadeUp 0.6s 0.5s ease both;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--c-orange); color: #fff;
    padding: 16px 28px; border-radius: var(--radius);
    font-size: 16px; font-weight: 500;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 0 40px rgba(255,78,0,0.3);
  }
  .btn-primary:hover {
    background: var(--c-orange-dark);
    transform: translateY(-2px);
    box-shadow: 0 8px 40px rgba(255,78,0,0.4);
  }
  .btn-arrow { transition: transform 0.2s; }
  .btn-primary:hover .btn-arrow { transform: translateX(4px); }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    border: 1px solid rgba(248,245,240,0.2);
    color: rgba(248,245,240,0.8);
    padding: 16px 24px; border-radius: var(--radius);
    font-size: 16px; transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: rgba(248,245,240,0.5); color: var(--c-white); }
  .hero-proof {
    display: flex; gap: 32px; flex-wrap: wrap;
    animation: fadeUp 0.6s 0.6s ease both;
  }
  .proof-item { display: flex; flex-direction: column; gap: 2px; }
  .proof-item strong { font-size: 22px; font-weight: 500; color: var(--c-white); }
  .proof-item span { font-size: 13px; color: rgba(248,245,240,0.5); }
  .proof-divider { width: 1px; background: var(--c-border); align-self: stretch; }
  .hero-scroll-indicator {
    position: absolute; bottom: 32px; right: 32px;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(248,245,240,0.3);
  }
  .scroll-line {
    width: 1px; height: 60px; background: linear-gradient(transparent, rgba(255,78,0,0.6));
    animation: scrollPulse 2s infinite;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes scrollPulse {
    0%, 100% { transform: scaleY(1); opacity: 0.4; }
    50% { transform: scaleY(1.3); opacity: 1; }
  }
  @media (max-width: 600px) {
    .hero { padding: 100px 0 60px; }
    .hero-proof { gap: 20px; }
    .proof-divider { display: none; }
    .hero-actions { flex-direction: column; }
    .btn-primary, .btn-ghost { width: 100%; justify-content: center; }
    .hero-scroll-indicator { display: none; }
  }
</style>
