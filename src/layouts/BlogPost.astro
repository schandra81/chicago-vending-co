---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';

export interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
  readTime: string;
  image: string;
  imageAlt: string;
  slug: string;
  tags?: string[];
}

const { title, description, category, date, readTime, image, imageAlt, slug, tags = [] } = Astro.props;

// Convert display date to ISO for schema
const dateMap: Record<string, string> = {
  'January': '01', 'February': '02', 'March': '03', 'April': '04',
  'May': '05', 'June': '06', 'July': '07', 'August': '08',
  'September': '09', 'October': '10', 'November': '11', 'December': '12',
};
const dateParts = date.split(' ');
const isoDate = dateParts.length === 3
  ? `${dateParts[2]}-${dateMap[dateParts[0]] || '01'}-${dateParts[1].replace(',', '').padStart(2, '0')}`
  : '2025-01-01';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": {
    "@type": "ImageObject",
    "url": image,
    "width": 1200,
    "height": 630,
  },
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": {
    "@type": "Organization",
    "name": "Chicago Vending Co.",
    "url": "https://chicagovendingco.com",
    "logo": { "@type": "ImageObject", "url": "https://chicagovendingco.com/logo.png" },
  },
  "publisher": {
    "@type": "Organization",
    "name": "Chicago Vending Co.",
    "url": "https://chicagovendingco.com",
    "logo": { "@type": "ImageObject", "url": "https://chicagovendingco.com/logo.png" },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://chicagovendingco.com/blog/${slug}`,
  },
  "keywords": tags.join(', ') + ', Chicago vending machines, vending machine service Chicago',
  "articleSection": category,
  "inLanguage": "en-US",
  "about": {
    "@type": "Thing",
    "name": "Vending Machine Services Chicago",
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://chicagovendingco.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://chicagovendingco.com/blog" },
    { "@type": "ListItem", "position": 3, "name": title, "item": `https://chicagovendingco.com/blog/${slug}` },
  ],
};
---

<Base
  title={`${title} | Chicago Vending Co. Blog`}
  description={description}
  canonical={`https://chicagovendingco.com/blog/${slug}`}
  ogImage={image}
  ogType="article"
  articleDate={isoDate}
  articleModified={isoDate}
  schemaType="blog"
>
  <Fragment slot="head-schema">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <Nav />
  <main>
    <section class="article-hero">
      <div class="article-hero-inner">
        <div class="breadcrumb">
          <a href="/">Home</a>
          <span class="breadcrumb-sep">›</span>
          <a href="/blog">Blog</a>
          <span class="breadcrumb-sep">›</span>
          <span>{category}</span>
        </div>
        <div class="article-category">{category}</div>
        <h1 class="article-title">{title}</h1>
        <div class="article-meta">
          <span>📅 {date}</span>
          <span>⏱ {readTime}</span>
          <span>✍️ Chicago Vending Co. Team</span>
          <span>📍 Chicago, IL</span>
        </div>
        {tags.length > 0 && (
          <div class="article-tags">
            {tags.map(tag => <span class="article-tag">{tag}</span>)}
          </div>
        )}
      </div>
      <img class="article-hero-img" src={image} alt={imageAlt} loading="eager" />
    </section>

    <div class="article-layout">
      <article class="article-body">
        <slot />
      </article>

      <aside class="article-sidebar">
        <div class="sidebar-cta">
          <div class="sidebar-cta-icon">🏙️</div>
          <h4>Free Vending for Your Chicago Location</h4>
          <p>Free installation. Weekly restocking. 4-hour service SLA. Takes 2 minutes to apply.</p>
          <a href="/#quiz" class="sidebar-btn">Check If You Qualify →</a>
        </div>

        <div class="sidebar-facts">
          <h4>Chicago Vending Co.</h4>
          <div class="fact-item"><strong>400+</strong><span>Chicago locations</span></div>
          <div class="fact-item"><strong>4.9★</strong><span>Google rating</span></div>
          <div class="fact-item"><strong>$0</strong><span>Installation cost</span></div>
          <div class="fact-item"><strong>4hr</strong><span>Service SLA</span></div>
        </div>

        <div class="sidebar-contact">
          <h4>Talk to a Chicago rep</h4>
          <a href="tel:+13125550190" class="sidebar-phone">📞 (312) 555-0190</a>
          <p>Mon–Fri, 8am–6pm CT</p>
        </div>
      </aside>
    </div>
  </main>

  <footer class="blog-footer">
    <div class="container">
      <div class="blog-footer-inner">
        <a href="/" class="logo">
          <span class="logo-icon">◈</span>
          <span>Chicago<strong>Vending</strong></span>
        </a>
        <div class="blog-footer-links">
          <a href="/blog">← All Articles</a>
          <a href="/">Home</a>
          <a href="/#quiz">Get Free Quote</a>
          <a href="/contact">Contact</a>
        </div>
        <p class="blog-footer-copy">&copy; 2025 Chicago Vending Co. Serving Chicago, IL and suburbs.</p>
      </div>
    </div>
  </footer>
</Base>

<style is:global>
  .article-hero {
    padding: 120px 0 0;
    background: var(--c-near-black);
  }
  .article-hero-inner {
    max-width: 820px; margin: 0 auto;
    padding: 0 24px 52px;
  }
  .breadcrumb {
    display: flex; gap: 8px; align-items: center;
    font-size: 13px; color: rgba(248,245,240,.4); margin-bottom: 20px;
  }
  .breadcrumb a:hover { color: var(--c-orange); }
  .breadcrumb-sep { color: rgba(248,245,240,.2); }
  .article-category {
    display: inline-block;
    background: rgba(255,78,0,.15); border: 1px solid rgba(255,78,0,.3);
    color: var(--c-orange-light); font-size: 12px; font-weight: 500;
    padding: 5px 14px; border-radius: 100px; margin-bottom: 20px;
  }
  .article-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 72px);
    font-weight: 400; line-height: 1.05; margin-bottom: 20px;
  }
  .article-meta {
    display: flex; gap: 20px; font-size: 13px;
    color: rgba(248,245,240,.45); flex-wrap: wrap; margin-bottom: 16px;
  }
  .article-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .article-tag {
    font-size: 12px; background: rgba(255,255,255,.06);
    border: 1px solid var(--c-border); padding: 4px 12px;
    border-radius: 100px; color: rgba(248,245,240,.55);
  }
  .article-hero-img {
    width: 100%; height: 460px; object-fit: cover;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    filter: brightness(0.85);
  }
  .article-layout {
    display: grid; grid-template-columns: 1fr 320px;
    gap: 60px; padding: 60px 24px 100px;
    max-width: 1200px; margin: 0 auto;
  }
  .article-body { min-width: 0; }
  .article-body h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 44px); font-weight: 400;
    margin: 48px 0 16px; color: var(--c-white);
  }
  .article-body h2:first-child { margin-top: 0; }
  .article-body h3 {
    font-size: 20px; font-weight: 500;
    margin: 32px 0 12px; color: var(--c-white);
  }
  .article-body p {
    font-size: 16px; color: rgba(248,245,240,.75);
    line-height: 1.8; margin-bottom: 20px;
  }
  .article-body ul, .article-body ol {
    margin: 0 0 20px 20px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .article-body li {
    font-size: 16px; color: rgba(248,245,240,.75);
    line-height: 1.7; padding-left: 4px;
  }
  .article-body strong { color: var(--c-white); font-weight: 500; }
  .article-body a { color: var(--c-orange); text-decoration: underline; text-underline-offset: 3px; }
  .article-body blockquote {
    border-left: 3px solid var(--c-orange);
    padding: 16px 20px; margin: 28px 0;
    background: rgba(255,78,0,.06);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .article-body blockquote p { color: rgba(248,245,240,.85); font-style: italic; margin: 0; }
  .callout {
    background: var(--c-dark); border: 1px solid var(--c-border);
    border-radius: var(--radius-lg); padding: 24px 28px; margin: 28px 0;
  }
  .callout-title { font-size: 16px; font-weight: 500; margin-bottom: 8px; }
  .callout p { margin: 0; font-size: 15px; }
  .article-img {
    width: 100%; border-radius: var(--radius-lg);
    margin: 32px 0; filter: brightness(0.85);
  }
  .article-img-caption {
    font-size: 13px; color: rgba(248,245,240,.4);
    text-align: center; margin-top: -20px; margin-bottom: 32px;
  }

  /* Sidebar */
  .article-sidebar {
    position: sticky; top: 100px;
    align-self: start; display: flex; flex-direction: column; gap: 24px;
  }
  .sidebar-cta {
    background: rgba(255,78,0,.1); border: 1px solid rgba(255,78,0,.25);
    border-radius: var(--radius-lg); padding: 24px; text-align: center;
  }
  .sidebar-cta-icon { font-size: 28px; margin-bottom: 10px; }
  .sidebar-cta h4 { font-size: 16px; font-weight: 500; margin-bottom: 10px; }
  .sidebar-cta p { font-size: 14px; color: rgba(248,245,240,.6); margin-bottom: 20px; line-height: 1.6; }
  .sidebar-btn {
    display: block; background: var(--c-orange); color: #fff;
    padding: 13px; border-radius: var(--radius);
    font-size: 15px; font-weight: 500; text-align: center; transition: background .2s;
  }
  .sidebar-btn:hover { background: var(--c-orange-dark); }
  .sidebar-facts {
    background: var(--c-dark); border: 1px solid var(--c-border);
    border-radius: var(--radius-lg); padding: 24px;
  }
  .sidebar-facts h4, .sidebar-contact h4 {
    font-size: 12px; letter-spacing: .08em; text-transform: uppercase;
    color: rgba(248,245,240,.4); font-weight: 500; margin-bottom: 16px;
  }
  .fact-item {
    display: flex; flex-direction: column; gap: 2px;
    padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,.04);
  }
  .fact-item:last-child { border-bottom: none; padding-bottom: 0; }
  .fact-item strong { font-size: 22px; font-weight: 500; color: var(--c-orange); }
  .fact-item span { font-size: 13px; color: rgba(248,245,240,.5); }
  .sidebar-contact {
    background: var(--c-dark); border: 1px solid var(--c-border);
    border-radius: var(--radius-lg); padding: 24px;
  }
  .sidebar-phone {
    display: block; font-size: 18px; font-weight: 500;
    color: var(--c-white); margin-bottom: 6px;
    transition: color .2s;
  }
  .sidebar-phone:hover { color: var(--c-orange); }
  .sidebar-contact p { font-size: 13px; color: rgba(248,245,240,.4); }

  /* Blog Footer */
  .blog-footer {
    background: var(--c-near-black);
    border-top: 1px solid var(--c-border); padding: 40px 0;
  }
  .blog-footer-inner {
    display: flex; flex-direction: column; gap: 16px; align-items: center; text-align: center;
  }
  .blog-footer .logo {
    display: flex; align-items: center; gap: 10px; font-size: 17px;
  }
  .blog-footer .logo-icon { color: var(--c-orange); }
  .blog-footer .logo strong { color: var(--c-orange); font-weight: 500; }
  .blog-footer-links {
    display: flex; gap: 28px; flex-wrap: wrap; justify-content: center;
  }
  .blog-footer-links a {
    font-size: 14px; color: rgba(248,245,240,.5); transition: color .2s;
  }
  .blog-footer-links a:hover { color: var(--c-orange); }
  .blog-footer-copy { font-size: 13px; color: rgba(248,245,240,.3); }

  @media (max-width: 900px) {
    .article-layout { grid-template-columns: 1fr; padding: 40px 24px 80px; }
    .article-sidebar { position: static; }
    .article-hero-img { height: 300px; }
  }
  @media (max-width: 600px) {
    .article-hero-img { height: 220px; }
    .article-meta { gap: 12px; }
  }
</style>
